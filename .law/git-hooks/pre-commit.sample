#!/usr/bin/env sh
# Sample pre-commit hook. Copy to .git/hooks/pre-commit and chmod +x, or
# wire via `git config core.hooksPath .law/git-hooks` to make this dir the
# active hook path.
#
# Runs the kit integrity checks. Humans bypass with --no-verify; agents
# bypass trivially too. Treat this as a human-facing safety net, not an
# agent enforcement gate.

set -e

.law/bin/verify-adapters
.law/bin/validate-contracts
.law/bin/check-coupling
.law/bin/check-counts
