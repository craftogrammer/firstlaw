#!/usr/bin/env python3
"""verify-adapters — check adapter projection blocks are intact.

Reads `.law/contracts/project.contract.json#adapters.patched_files[].path`.
For each path, confirms the file exists and still contains the exact
`<!-- BEGIN .law/CONSTITUTION-FIRST -->` and `<!-- END .law/CONSTITUTION-FIRST -->`
delimiter pair.

Exit 0 on pass, non-zero on any failure. Silent on pass.
"""
import json
import sys
from pathlib import Path

CONTRACT = Path(".law/contracts/project.contract.json")
BEGIN = "<!-- BEGIN .law/CONSTITUTION-FIRST -->"
END = "<!-- END .law/CONSTITUTION-FIRST -->"


def main() -> int:
    if not CONTRACT.exists():
        print(f"verify-adapters: missing {CONTRACT}", file=sys.stderr)
        return 2
    try:
        data = json.loads(CONTRACT.read_text())
    except json.JSONDecodeError as e:
        print(f"verify-adapters: invalid JSON in {CONTRACT}: {e}", file=sys.stderr)
        return 2

    paths = [
        entry.get("path", "")
        for entry in data.get("adapters", {}).get("patched_files", [])
    ]
    paths = [p for p in paths if p]
    if not paths:
        return 0

    failed = 0
    for p in paths:
        path = Path(p)
        if not path.exists():
            print(f"verify-adapters: missing adapter file: {p}", file=sys.stderr)
            failed += 1
            continue
        text = path.read_text(errors="replace")
        if BEGIN not in text:
            print(f"verify-adapters: missing BEGIN delimiter in {p}", file=sys.stderr)
            failed += 1
        if END not in text:
            print(f"verify-adapters: missing END delimiter in {p}", file=sys.stderr)
            failed += 1

    return 1 if failed else 0


if __name__ == "__main__":
    sys.exit(main())
