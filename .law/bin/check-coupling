#!/bin/sh
"exec" "python3" "$0" "$@"
""":"
:<<'END_SHELL_CLOAK'
"""
"""check-coupling — enforce cross-domain dep edges per dependency-rules.contract.json.

Walk the working tree, extract imports from supported source files via regex,
resolve each import to a file path, and check every cross-domain edge against
`.law/contracts/dependency-rules.contract.json`. Default stance is deny: an
edge not listed in `allowed` is a violation. An edge listed in `forbidden` is
a violation regardless of `allowed`.

Silent on pass. Exits 1 on violations, 2 on internal error, 0 when the domain
map declares no domains (pre-bootstrap repos).

Supported extensions: .ts, .tsx, .js, .jsx, .mjs, .py. Skipped roots: `.law/`,
`node_modules/`, `.git/`, `__pycache__/`, `dist/`, `build/`.

Future work: swap regex extraction for AST-based parsing (TypeScript compiler
API, Python `ast`) to cover dynamic imports, type-only imports, and tsconfig
`paths` aliases. Out of scope for v1.4.
"""
import json
import re
import sys
from pathlib import Path

ROOT = Path(".")
DOMAIN_MAP = Path(".law/contracts/domain-map.contract.json")
DEP_RULES = Path(".law/contracts/dependency-rules.contract.json")

JS_EXTS = (".ts", ".tsx", ".js", ".jsx", ".mjs")
SOURCE_EXTS = {*JS_EXTS, ".py"}
SKIP_DIRS = {".law", "node_modules", ".git", "__pycache__", "dist", "build"}

# TS/JS: static import, side-effect import, dynamic import(), require(), re-exports.
JS_IMPORT_RE = re.compile(
    r"""(?:^|\s)(?:import\s+(?:[^'"`;]+?\s+from\s+)?|export\s+(?:\*|\{[^}]*\})\s+from\s+|import\s*\(\s*|require\s*\(\s*)['"]([^'"]+)['"]""",
    re.MULTILINE,
)
# Python: `from X import ...` or `import X[, Y as Z]`.
PY_FROM_RE = re.compile(r"^\s*from\s+(\.*[\w.]+)\s+import\s+", re.MULTILINE)
PY_IMPORT_RE = re.compile(r"^\s*import\s+([\w.]+(?:\s*,\s*[\w.]+)*)", re.MULTILINE)


def load_json(path: Path):
    return json.loads(path.read_text(encoding="utf-8"))


def domain_roots(domain_map: dict) -> list[tuple[str, Path]]:
    """Return [(domain_id, absolute_root_path), ...]. Accept `path` as str or list."""
    out: list[tuple[str, Path]] = []
    for d in domain_map.get("domains", []):
        did = d.get("id")
        raw = d.get("path")
        if not did or not raw:
            continue
        paths = raw if isinstance(raw, list) else [raw]
        for p in paths:
            if not isinstance(p, str) or not p:
                continue
            out.append((did, (ROOT / p).resolve()))
    return out


def edge_set(items: list) -> set[tuple[str, str]]:
    return {(e["from"], e["to"]) for e in items if "from" in e and "to" in e}


def domain_of(file_path: Path, roots: list[tuple[str, Path]]) -> str | None:
    try:
        resolved = file_path.resolve()
    except OSError:
        return None
    for did, root in roots:
        try:
            resolved.relative_to(root)
        except ValueError:
            continue
        return did
    return None


def walk_sources(root: Path):
    for p in root.rglob("*"):
        if p.suffix not in SOURCE_EXTS or not p.is_file():
            continue
        if any(part in SKIP_DIRS for part in p.relative_to(root).parts):
            continue
        yield p


def line_of(text: str, offset: int) -> int:
    return text.count("\n", 0, offset) + 1


def resolve_js(spec: str, importer: Path) -> Path | None:
    """Resolve a TS/JS import spec to a file path. Skip bare module specs."""
    if not spec.startswith("."):
        return None
    base = (importer.parent / spec).resolve()
    if base.is_file():
        return base
    for ext in JS_EXTS:
        cand = Path(str(base) + ext)
        if cand.is_file():
            return cand
    if base.is_dir():
        for ext in JS_EXTS:
            idx = base / f"index{ext}"
            if idx.is_file():
                return idx
    return base if base.exists() else None


def resolve_py(mod: str, importer: Path, project_root: Path) -> Path | None:
    """Resolve a Python module reference to a file path."""
    if mod.startswith("."):
        level = len(mod) - len(mod.lstrip("."))
        name = mod[level:]
        base = importer.parent
        for _ in range(level - 1):
            base = base.parent
        parts = name.split(".") if name else []
    else:
        base = project_root
        parts = mod.split(".")
    target = base
    for part in parts:
        target = target / part
    for cand in (target.with_suffix(".py"), target / "__init__.py"):
        if cand.is_file():
            return cand.resolve()
    return None


def extract_js_imports(text: str) -> list[tuple[int, str]]:
    return [(line_of(text, m.start()), m.group(1)) for m in JS_IMPORT_RE.finditer(text)]


def extract_py_imports(text: str) -> list[tuple[int, str]]:
    out = [(line_of(text, m.start()), m.group(1)) for m in PY_FROM_RE.finditer(text)]
    for m in PY_IMPORT_RE.finditer(text):
        line = line_of(text, m.start())
        for name in m.group(1).split(","):
            n = name.strip().split(" as ")[0].strip()
            if n:
                out.append((line, n))
    return out


def main() -> int:
    if not DOMAIN_MAP.exists() or not DEP_RULES.exists():
        return 0
    try:
        dmap = load_json(DOMAIN_MAP)
        drules = load_json(DEP_RULES)
    except (json.JSONDecodeError, OSError) as exc:
        print(f"check-coupling: cannot parse contract: {exc}", file=sys.stderr)
        return 2

    roots = domain_roots(dmap)
    if not roots:
        return 0
    allowed = edge_set(drules.get("allowed", []))
    forbidden = edge_set(drules.get("forbidden", []))

    project_root = ROOT.resolve()
    violations: list[str] = []

    for src in walk_sources(ROOT):
        src_domain = domain_of(src, roots)
        if src_domain is None:
            continue
        try:
            text = src.read_text(encoding="utf-8", errors="replace")
        except OSError:
            continue

        is_js = src.suffix in JS_EXTS
        imports = extract_js_imports(text) if is_js else extract_py_imports(text)

        for line, spec in imports:
            target = resolve_js(spec, src) if is_js else resolve_py(spec, src, project_root)
            if target is None:
                continue
            tgt_domain = domain_of(target, roots)
            if tgt_domain is None or tgt_domain == src_domain:
                continue
            edge = (src_domain, tgt_domain)
            if edge in forbidden:
                violations.append(
                    f"`{src}`:{line} [{src_domain} -> {tgt_domain}] "
                    f"import resolves to `{target}`. Listed in `forbidden`."
                )
                continue
            if edge not in allowed:
                violations.append(
                    f"`{src}`:{line} [{src_domain} -> {tgt_domain}] "
                    f"import resolves to `{target}`. Not in `allowed`."
                )

    if violations:
        for v in violations:
            print(v, file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
