#!/bin/sh
"exec" "python3" "$0" "$@"
""":"
:<<'END_SHELL_CLOAK'
"""
"""check-setup — firstlaw self-heal on cold-read.

Detects and heals the narrow set of deterministic, safe-to-automate drift
between the kit as it ships and the kit as it lives in a consuming project.
Runs via polyglot shebang: `bash check-setup`, `./check-setup`, and
`python3 check-setup` all route through `python3`.

Heals (auto, atomic commit per heal when tree is clean at start):
  - `doc-taxonomy.contract.json` missing a layer the schema declares
    (bundled canonical definitions below; extend CANONICAL_LAYERS when new
    layers ship with a new kit version)
  - `.claude/skills/` missing when `.law/skills/` exists (symlink on Unix,
    recursive copy on Windows)
  - `.law/context/last-check.log` missing (writes this run's stamp)
  - `.git/hooks/pre-commit` missing the kit-managed delimited block
  - `CONSTITUTION.md` Amendment log row per contract heal (§9)

Surfaces (no auto-heal):
  - `KIT_VERSION` on disk differs from what `expected_kit_version()` reads
    from the root `KIT_VERSION` file (the single source of truth shipped by
    install.sh; no hardcoded constant)
  - `project.contract.json#enforcement.coupled_paths` empty while a
    top-level `src/`, `lib/`, or `app/` exists
  - `pending-questions.json` entries with `blocking: true`
  - `current-system.json#contradiction_map` entries with `status` not
    `"resolved"` (brownfield: pass-with-warning when every unresolved
    entry carries a `related_plan` path that exists on disk)
  - `*.md` files whose path does not match any `location_pattern` in
    `doc-taxonomy.contract.json#layers[]` (classification requires agent
    judgment, so surface-only; skips kit-managed skill/template paths)

Exit codes:
  0 — clean, or cleanly healed (including dirty-tree heals left uncommitted)
  1 — irreducible blockers surfaced that require human decision
  2 — internal error (bad JSON, git failure, etc.)

Kit-author contract:
  When a new kit version adds a doc-taxonomy layer to the schema, extend
  CANONICAL_LAYERS in this file in the same commit. check-setup heals
  downstream projects on next cold-read.
"""
import glob
import json
import os
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path


def expected_kit_version() -> str:
    """Single source of truth: the root KIT_VERSION file shipped by install.sh.

    A function (not a constant) so future kit authors cannot drift the number
    from the file contents; the file itself is authoritative every run.
    """
    kv = Path("KIT_VERSION")
    if kv.exists():
        return kv.read_text(encoding="utf-8").strip()
    return "unknown"


CANONICAL_LAYERS = {
    "skill": {
        "id": "skill",
        "purpose": "Loadable capsule projecting constitution/contract law into a runtime-trigger + imperative-body form (YAML frontmatter with name + description, keyed to the cognitive moment that triggers it). Authored by agents via the authoring-project-skills skill; regenerable; subordinate to contracts. Never a source of truth — contracts and CONSTITUTION.md remain authoritative.",
        "mutability": "regenerable",
        "lifetime": "regenerate when source law (constitution/contracts) changes",
        "authority": "projection",
        "location_pattern": [".law/skills/**/SKILL.md", ".claude/skills/**/SKILL.md"],
    }
}

HOOK_BEGIN = "<!-- BEGIN .law/CONSTITUTION-FIRST -->"
HOOK_END = "<!-- END .law/CONSTITUTION-FIRST -->"
HOOK_BLOCK = f"""#!/usr/bin/env sh
# {HOOK_BEGIN}
# kit-managed: runs firstlaw integrity checks. Do not edit between delimiters.
set -e
.law/bin/verify-adapters
.law/bin/validate-contracts
.law/bin/check-coupling
.law/bin/check-counts
# {HOOK_END}
"""

SCHEMA_PATH = Path(".law/schemas/doc-taxonomy.schema.json")
CONTRACT_PATH = Path(".law/contracts/doc-taxonomy.contract.json")
PROJECT_CONTRACT = Path(".law/contracts/project.contract.json")
SYS_CONTEXT = Path(".law/context/current-system.json")
PENDING = Path(".law/context/pending-questions.json")
LAST_CHECK = Path(".law/context/last-check.log")
LAW_SKILLS = Path(".law/skills")
CLAUDE_SKILLS = Path(".claude/skills")
HOOK = Path(".git/hooks/pre-commit")
CONSTITUTION = Path("CONSTITUTION.md")
KIT_VERSION_FILE = Path("KIT_VERSION")

BRIDGE_RELOAD_HINT = (
    "skills bridge populated; reload your agent runtime to register the "
    "skill directories."
)


def die(msg: str) -> int:
    print(f"check-setup: {msg}", file=sys.stderr)
    return 2


def load_json(path: Path):
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as e:
        raise ValueError(f"{path}: {e}")


def write_json(path: Path, data) -> None:
    path.write_text(json.dumps(data, indent=2) + "\n", encoding="utf-8")


def run_git(args: list[str]) -> subprocess.CompletedProcess:
    return subprocess.run(
        ["git", *args], check=False, capture_output=True, text=True
    )


def tree_clean() -> bool:
    r = run_git(["status", "--porcelain"])
    if r.returncode != 0:
        raise RuntimeError(f"git status failed: {r.stderr.strip()}")
    return r.stdout.strip() == ""


def git_commit(paths: list[Path], message: str) -> str:
    for p in paths:
        r = run_git(["add", "--", str(p)])
        if r.returncode != 0:
            raise RuntimeError(f"git add {p}: {r.stderr.strip()}")
    r = run_git(["commit", "-m", message])
    if r.returncode != 0:
        raise RuntimeError(f"git commit: {r.stderr.strip()}")
    rev = run_git(["rev-parse", "--short", "HEAD"])
    if rev.returncode != 0:
        raise RuntimeError(f"git rev-parse: {rev.stderr.strip()}")
    return rev.stdout.strip()


def now_iso() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def today() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%d")


def schema_layer_ids() -> list[str]:
    data = load_json(SCHEMA_PATH)
    try:
        return list(
            data["properties"]["layers"]["items"]["properties"]["id"]["enum"]
        )
    except (KeyError, TypeError):
        return []


def contract_layer_ids(data) -> list[str]:
    return [L.get("id") for L in data.get("layers", []) if isinstance(L, dict)]


def append_amendment_row(description: str) -> None:
    text = CONSTITUTION.read_text(encoding="utf-8")
    row = f"| {today()} | {description} | firstlaw check-setup |"
    if row in text:
        return
    lines = text.splitlines()
    # append after the last non-empty table row under "## Amendment log"
    try:
        start = next(i for i, L in enumerate(lines) if L.strip() == "## Amendment log")
    except StopIteration:
        return
    insert_at = len(lines)
    for i in range(start + 1, len(lines)):
        L = lines[i].rstrip()
        if L.startswith("|") and not L.startswith("|---"):
            insert_at = i + 1
        elif L.startswith("##") and i > start:
            break
    lines.insert(insert_at, row)
    CONSTITUTION.write_text("\n".join(lines) + ("\n" if text.endswith("\n") else ""), encoding="utf-8")


class Heal:
    """One heal action. `paths` empty means disk-only (no commit)."""

    __slots__ = ("desc", "paths", "message", "sha", "disk_only_reason")

    def __init__(self, desc: str, paths: list[Path], message: str, disk_only_reason: str = ""):
        self.desc = desc
        self.paths = paths
        self.message = message
        self.sha = ""
        self.disk_only_reason = disk_only_reason


def heal_missing_layers(heals: list[Heal]) -> None:
    if not (SCHEMA_PATH.exists() and CONTRACT_PATH.exists()):
        return
    schema_ids = schema_layer_ids()
    contract = load_json(CONTRACT_PATH)
    have = set(contract_layer_ids(contract))
    for layer_id in schema_ids:
        if layer_id in have:
            continue
        canon = CANONICAL_LAYERS.get(layer_id)
        if canon is None:
            # no bundled definition — surface, do not heal
            continue
        contract.setdefault("layers", []).append(canon)
        contract["last_validated_at"] = now_iso()
        write_json(CONTRACT_PATH, contract)
        desc = f"add `{layer_id}` layer to doc-taxonomy contract"
        append_amendment_row(desc + ".")
        heals.append(
            Heal(desc, [CONTRACT_PATH, CONSTITUTION], f"firstlaw: heal {desc}.")
        )
        have.add(layer_id)


def heal_claude_skills_bridge(heals: list[Heal]) -> bool:
    if not LAW_SKILLS.exists() or not any(LAW_SKILLS.iterdir()):
        return False
    if CLAUDE_SKILLS.exists() and any(CLAUDE_SKILLS.iterdir()):
        return False
    CLAUDE_SKILLS.parent.mkdir(parents=True, exist_ok=True)
    on_windows = os.name == "nt" or sys.platform.startswith("win")
    if CLAUDE_SKILLS.exists():
        # empty dir/link — remove so the symlink or copy lands cleanly
        try:
            CLAUDE_SKILLS.rmdir()
        except OSError:
            shutil.rmtree(CLAUDE_SKILLS)
    if on_windows:
        shutil.copytree(LAW_SKILLS, CLAUDE_SKILLS)
        desc = "copy `.law/skills/` -> `.claude/skills/` (Windows bridge)"
    else:
        os.symlink("../.law/skills", CLAUDE_SKILLS)
        desc = "symlink `.claude/skills/` -> `../.law/skills/`"
    heals.append(Heal(desc, [CLAUDE_SKILLS], f"firstlaw: heal {desc}."))
    return True


def plan_pre_commit_hook() -> tuple[str, str] | None:
    """Plan the hook heal. Defer the disk write until after prior heal
    commits complete; otherwise the freshly-written hook runs during
    those earlier commits, before it is itself installed.
    Returns (content, description) or None when nothing to heal.
    """
    if not HOOK.parent.is_dir():
        return None
    if not HOOK.exists():
        return (HOOK_BLOCK, "install kit-managed pre-commit block")
    text = HOOK.read_text(encoding="utf-8")
    if HOOK_BEGIN in text and HOOK_END in text:
        return None
    body = text
    if body.startswith("#!"):
        nl = body.find("\n")
        body = body[nl + 1 :] if nl != -1 else ""
    new = HOOK_BLOCK + (body if body.startswith("\n") or body == "" else "\n" + body)
    return (new, "insert kit-managed block into existing pre-commit")


def apply_pre_commit_hook(content: str) -> None:
    HOOK.write_text(content, encoding="utf-8")
    try:
        HOOK.chmod(0o755)
    except OSError:
        pass


def project_mode() -> str:
    if not PROJECT_CONTRACT.exists():
        return ""
    try:
        pdata = load_json(PROJECT_CONTRACT)
    except ValueError:
        return ""
    if not isinstance(pdata, dict):
        return ""
    mode = pdata.get("mode", "")
    return mode if isinstance(mode, str) else ""


def plan_backed(entry: dict) -> bool:
    plan = entry.get("related_plan")
    return isinstance(plan, str) and bool(plan.strip()) and Path(plan).exists()


UNCLASSIFIED_HARD_SKIPS = (
    ".law/skills/**/SKILL.md",
    ".law/templates/**",
    "node_modules/**",
    ".git/**",
)


def _expand_patterns(patterns) -> set[str]:
    """Expand glob patterns (including `**`) to a set of forward-slash
    relative paths. Uses `glob.glob(recursive=True)` for `**` support.
    """
    matched: set[str] = set()
    for pat in patterns:
        if not isinstance(pat, str) or not pat:
            continue
        for hit in glob.glob(pat, recursive=True):
            matched.add(hit.replace(os.sep, "/"))
    return matched


def _all_md_files() -> list[str]:
    """All tracked-looking `*.md` paths (forward-slash, relative). Prunes
    `node_modules/` and `.git/` at descent time — load-bearing for perf.
    """
    out: list[str] = []
    for root, dirs, files in os.walk(".", topdown=True):
        dirs[:] = [d for d in dirs if d not in ("node_modules", ".git")]
        for f in files:
            if f.endswith(".md"):
                rel = os.path.join(root, f).replace(os.sep, "/")
                if rel.startswith("./"):
                    rel = rel[2:]
                out.append(rel)
    return out


def unclassified_docs() -> list[str]:
    """`*.md` paths matching no declared `location_pattern` and no hard-skip.
    Returns [] when the contract is missing or malformed (fail-open matches
    existing `project_mode()` pattern; validate-contracts surfaces schema issues).
    """
    if not CONTRACT_PATH.exists():
        return []
    try:
        contract = load_json(CONTRACT_PATH)
    except ValueError:
        return []
    patterns: list[str] = []
    for layer in contract.get("layers", []):
        if not isinstance(layer, dict):
            continue
        loc = layer.get("location_pattern", [])
        if isinstance(loc, list):
            patterns.extend(p for p in loc if isinstance(p, str))
    allowed = _expand_patterns(patterns) | _expand_patterns(UNCLASSIFIED_HARD_SKIPS)
    return sorted(p for p in _all_md_files() if p not in allowed)


def surface_checks(
    surfaced: list[str], warnings: list[str], mode: str
) -> int:
    blockers = 0

    expected = expected_kit_version()
    if KIT_VERSION_FILE.exists():
        on_disk = KIT_VERSION_FILE.read_text(encoding="utf-8").strip()
        if on_disk != expected:
            surfaced.append(
                f"KIT_VERSION on disk is `{on_disk}`; script expects "
                f"`{expected}`. Run `install.sh --force` to re-fetch kit files."
            )

    if PROJECT_CONTRACT.exists():
        try:
            pdata = load_json(PROJECT_CONTRACT)
        except ValueError:
            pdata = None
        if pdata is not None:
            coupled = pdata.get("enforcement", {}).get("coupled_paths", [])
            if not coupled:
                for d in ("src", "lib", "app"):
                    if Path(d).is_dir():
                        surfaced.append(
                            f"`project.contract.json#enforcement.coupled_paths` empty "
                            f"but top-level `{d}/` exists; declare coupling or accept the default no-op."
                        )
                        break

    if PENDING.exists():
        try:
            pq = load_json(PENDING)
        except ValueError:
            pq = None
        if isinstance(pq, dict):
            for q in pq.get("questions", []):
                if isinstance(q, dict) and q.get("blocking") is True:
                    qid = q.get("id", "<no-id>")
                    surfaced.append(f"blocking pending-question: `{qid}`.")
                    blockers += 1

    if SYS_CONTEXT.exists():
        try:
            sd = load_json(SYS_CONTEXT)
        except ValueError:
            sd = None
        if isinstance(sd, dict):
            entries = [
                c for c in sd.get("contradiction_map", []) if isinstance(c, dict)
            ]
            unresolved = [
                c for c in entries if c.get("status") != "resolved"
            ]
            if mode == "brownfield" and unresolved:
                for c in unresolved:
                    cid = c.get("id", "<no-id>")
                    if plan_backed(c):
                        plan = c.get("related_plan", "")
                        warnings.append(
                            f"unresolved contradiction `{cid}` — plan: `{plan}`."
                        )
                        continue
                    plan = c.get("related_plan")
                    reason = (
                        "missing `related_plan`"
                        if not (isinstance(plan, str) and plan.strip())
                        else f"`related_plan` path `{plan}` not found"
                    )
                    surfaced.append(
                        f"unresolved contradiction `{cid}`: {reason}."
                    )
                    blockers += 1
            else:
                for c in unresolved:
                    cid = c.get("id", "<no-id>")
                    surfaced.append(f"unresolved contradiction: `{cid}`.")
                    blockers += 1

    for path in unclassified_docs():
        surfaced.append(
            f"unclassified doc: {path} — classify per doc-taxonomy "
            f"or move to matching location_pattern."
        )
        blockers += 1

    return blockers


def format_heal_line(h: Heal) -> str:
    if h.sha:
        return f"  - {h.desc} — commit: {h.sha}"
    reason = h.disk_only_reason or "disk-only"
    return f"  - {h.desc} — {reason}"


def print_report(
    heals: list[Heal],
    surfaced: list[str],
    warnings: list[str],
    dirty_note: str,
    bridge_populated: bool,
) -> None:
    print(f"firstlaw check-setup v{expected_kit_version()}")
    if heals:
        print("heals:")
        for h in heals:
            print(format_heal_line(h))
    if surfaced:
        print("surfaced (no auto-heal):")
        for s in surfaced:
            print(f"  - {s}")
    if dirty_note:
        print(dirty_note)
    for w in warnings:
        print(w, file=sys.stderr)
    if bridge_populated:
        print(BRIDGE_RELOAD_HINT)


def write_last_check_log(
    heals: list[Heal],
    surfaced: list[str],
    warnings: list[str],
    blockers: int,
    clean_disposition: str,
) -> None:
    LAST_CHECK.parent.mkdir(parents=True, exist_ok=True)
    lines = [
        f"{now_iso()} firstlaw check-setup v{expected_kit_version()} "
        f"healed={len(heals)} surfaced={len(surfaced)} blockers={blockers}"
    ]
    if heals:
        lines.append("heals:")
        for h in heals:
            lines.append(format_heal_line(h))
    if surfaced:
        lines.append("surfaced:")
        for s in surfaced:
            lines.append(f"  - {s}")
    if warnings:
        lines.append("warnings:")
        for w in warnings:
            lines.append(f"  - {w}")
    if clean_disposition:
        lines.append(clean_disposition)
    LAST_CHECK.write_text("\n".join(lines) + "\n", encoding="utf-8")


def main() -> int:
    try:
        clean_at_start = tree_clean()
    except RuntimeError as e:
        return die(str(e))

    heals: list[Heal] = []
    bridge_populated = False
    hook_plan: tuple[str, str] | None = None

    try:
        heal_missing_layers(heals)
        bridge_populated = heal_claude_skills_bridge(heals)
        hook_plan = plan_pre_commit_hook()
    except (ValueError, OSError, RuntimeError) as e:
        return die(str(e))

    mode = project_mode()
    surfaced: list[str] = []
    warnings: list[str] = []
    try:
        blockers = surface_checks(surfaced, warnings, mode)
    except (ValueError, OSError) as e:
        return die(str(e))

    dirty_note = ""
    if heals or hook_plan is not None:
        if clean_at_start:
            try:
                for h in heals:
                    if h.paths:
                        h.sha = git_commit(h.paths, h.message)
            except RuntimeError as e:
                return die(str(e))
        else:
            for h in heals:
                if h.paths:
                    h.disk_only_reason = "uncommitted (dirty tree at start)"
            dirty_note = (
                "working tree was dirty at start; heals NOT committed — "
                "review `git diff` and commit the heals alongside your work "
                "before proceeding with the task."
            )
        if hook_plan is not None:
            # hooks live outside the git index; apply on disk only
            apply_pre_commit_hook(hook_plan[0])
            heals.append(
                Heal(
                    hook_plan[1],
                    [],
                    "",
                    disk_only_reason="disk-only (`.git/hooks/` is git-untracked)",
                )
            )

    clean_run = not heals and not surfaced and not warnings and not dirty_note
    clean_disposition = ""
    if clean_run:
        clean_disposition = (
            f"firstlaw check-setup v{expected_kit_version()} — clean (0 heals, "
            f"0 surfaced). last-check.log updated."
        )
        print(clean_disposition)
    else:
        print_report(heals, surfaced, warnings, dirty_note, bridge_populated)

    try:
        write_last_check_log(heals, surfaced, warnings, blockers, clean_disposition)
    except OSError as e:
        return die(str(e))

    if blockers:
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
