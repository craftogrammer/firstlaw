#!/usr/bin/env sh
# validate-contracts — validate every .law/contracts/*.contract.json against
# its declared schema.
#
# Picks the first available validator:
#   check-jsonschema   (pipx install check-jsonschema)
#   ajv                (npm install -g ajv-cli)
#
# Fails closed if neither is present.

set -eu

SCHEMAS_DIR=".law/schemas"
CONTRACTS_DIR=".law/contracts"

# Pick a validator in priority order:
#   1. check-jsonschema       (pipx install check-jsonschema)
#   2. ajv                    (npm install -g ajv-cli)
#   3. npx ajv-cli            (zero pre-install; requires Node)
if command -v check-jsonschema >/dev/null 2>&1; then
  validator=check-jsonschema
elif command -v ajv >/dev/null 2>&1; then
  validator=ajv
elif command -v npx >/dev/null 2>&1; then
  validator=npx-ajv
else
  cat >&2 <<'EOF'
validate-contracts: no JSON Schema validator available.
install one:
  pipx install check-jsonschema                        # Python path (simplest)
  npm install -g ajv-cli ajv-formats                   # Node path (persistent; both packages required)
  (or have `npx` on PATH — we'll invoke ajv-cli + ajv-formats transparently)
EOF
  exit 2
fi

fail=0
for contract in "$CONTRACTS_DIR"/*.contract.json; do
  [ -f "$contract" ] || continue
  base=$(basename "$contract" .contract.json)
  schema="$SCHEMAS_DIR/$base.schema.json"
  if [ ! -f "$schema" ]; then
    printf 'validate-contracts: no schema for %s (expected %s)\n' "$contract" "$schema" >&2
    fail=1
    continue
  fi
  case "$validator" in
    check-jsonschema)
      check-jsonschema --schemafile "$schema" "$contract" >&2 || fail=1
      ;;
    ajv)
      # -c ajv-formats loads the formats plugin (date-time, uri, etc.).
      # Requires `npm install -g ajv-formats` alongside ajv-cli.
      ajv validate -s "$schema" -d "$contract" --spec=draft2020 -c ajv-formats >&2 || fail=1
      ;;
    npx-ajv)
      # --package=... pulls both ajv-cli and ajv-formats into the npx cache.
      npx --yes --package=ajv-cli --package=ajv-formats ajv validate \
        -s "$schema" -d "$contract" --spec=draft2020 -c ajv-formats >&2 || fail=1
      ;;
  esac
done

exit $fail
