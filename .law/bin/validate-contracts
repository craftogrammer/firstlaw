#!/bin/sh
"exec" "python3" "$0" "$@"
"""validate-contracts — validate every .law/contracts/*.contract.json against its declared schema.

Selects the first available validator:
  check-jsonschema   (pipx install check-jsonschema)
  ajv                (npm install -g ajv-cli ajv-formats)
  npx ajv-cli        (zero pre-install; requires Node)

Fails closed when none are available. Polyglot shebang: `bash`, direct
exec, and `python3` invocations all route through python3.
"""

import shutil
import subprocess
import sys
from pathlib import Path

SCHEMAS_DIR = Path(".law/schemas")
CONTRACTS_DIR = Path(".law/contracts")

NO_VALIDATOR_MESSAGE = (
    "validate-contracts: no JSON Schema validator available.\n"
    "install one:\n"
    "  pipx install check-jsonschema\n"
    "  npm install -g ajv-cli ajv-formats\n"
    "  (or have `npx` on PATH)\n"
)


def pick_validator():
    if shutil.which("check-jsonschema"):
        return "check-jsonschema"
    if shutil.which("ajv"):
        return "ajv"
    if shutil.which("npx"):
        return "npx-ajv"
    return None


def run(cmd):
    """Run cmd with stdout redirected to stderr (matches the original shell `>&2`).

    Returns True only when the validator exits 0 AND writes nothing to stderr.
    Any captured stderr is re-emitted so the user sees WHY validation failed.
    """
    result = subprocess.run(
        cmd,
        check=False,
        stdout=sys.stderr.fileno(),
        stderr=subprocess.PIPE,
    )
    if result.stderr:
        sys.stderr.buffer.write(result.stderr)
        sys.stderr.flush()
    return result.returncode == 0 and not result.stderr


def validate(validator, schema, contract):
    if validator == "check-jsonschema":
        return run(["check-jsonschema", "--schemafile", str(schema), str(contract)])
    if validator == "ajv":
        return run([
            "ajv", "validate",
            "-s", str(schema),
            "-d", str(contract),
            "--spec=draft2020",
            "-c", "ajv-formats",
        ])
    if validator == "npx-ajv":
        return run([
            "npx", "--yes",
            "--package=ajv-cli",
            "--package=ajv-formats",
            "ajv", "validate",
            "-s", str(schema),
            "-d", str(contract),
            "--spec=draft2020",
            "-c", "ajv-formats",
        ])
    raise RuntimeError(f"unknown validator: {validator}")


def main():
    validator = pick_validator()
    if validator is None:
        sys.stderr.write(NO_VALIDATOR_MESSAGE)
        return 2

    fail = 0
    for contract in sorted(CONTRACTS_DIR.glob("*.contract.json")):
        base = contract.name[: -len(".contract.json")]
        schema = SCHEMAS_DIR / f"{base}.schema.json"
        if not schema.is_file():
            sys.stderr.write(
                f"validate-contracts: no schema for {contract} (expected {schema})\n"
            )
            fail |= 1
            continue
        if not validate(validator, schema, contract):
            fail |= 1

    return 1 if fail else 0


if __name__ == "__main__":
    sys.exit(main())
