{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repo-constitution-kit/schemas/doc-taxonomy.schema.json",
  "title": "Doc taxonomy contract",
  "description": "Declares the document layers that exist in the repo, their mutability, location rules, and what happens when a document cannot be classified.",
  "type": "object",
  "required": [
    "schema_version",
    "owner",
    "purpose",
    "authoritative",
    "generated_from",
    "last_validated_at",
    "status",
    "rules",
    "layers"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "owner": { "type": "string" },
    "purpose": { "type": "string" },
    "authoritative": { "type": "boolean" },
    "generated_from": {
      "type": "object",
      "required": ["subagent", "run_at"],
      "properties": {
        "subagent": { "type": "string" },
        "run_at": { "type": ["string", "null"], "format": "date-time" },
        "kit_version": { "type": ["string", "null"] }
      }
    },
    "last_validated_at": { "type": ["string", "null"], "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["skeleton", "bootstrapping", "active", "stale"]
    },
    "rules": {
      "type": "object",
      "required": ["every_doc_has_exactly_one_layer", "unclassified_docs_forbidden", "on_unclassified"],
      "properties": {
        "every_doc_has_exactly_one_layer": { "type": "boolean" },
        "unclassified_docs_forbidden": { "type": "boolean" },
        "on_unclassified": {
          "type": "string",
          "enum": ["halt-and-classify", "move-to-quarantine", "mark-and-surface"]
        }
      }
    },
    "layers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "purpose", "mutability", "lifetime", "authority", "location_pattern"],
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "runtime-truth",
              "constitution",
              "contract",
              "doctrine",
              "charter",
              "temporary-plan",
              "context-snapshot",
              "adapter",
              "code-comment",
              "generated",
              "external-reference"
            ]
          },
          "purpose": { "type": "string" },
          "mutability": {
            "type": "string",
            "enum": ["timeless", "amendable", "temporary", "regenerable", "read-only-projection"]
          },
          "lifetime": { "type": "string" },
          "authority": {
            "type": "string",
            "enum": ["highest", "compiled-law", "elaboration", "non-authoritative", "projection"]
          },
          "location_pattern": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Glob patterns describing where documents of this layer may live."
          },
          "rename_rules": { "type": "string" }
        }
      }
    },
    "classification_directives": {
      "type": "object",
      "properties": {
        "on_new_doc": { "type": "array", "items": { "type": "string" } },
        "on_ambiguous_layer": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
