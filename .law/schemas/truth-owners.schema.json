{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://firstlaw/schemas/truth-owners.schema.json",
  "title": "Truth owners contract",
  "description": "Declares the single writer for each piece of runtime truth. Readers may be many; writers are one.",
  "type": "object",
  "required": [
    "schema_version",
    "owner",
    "purpose",
    "authoritative",
    "generated_from",
    "last_validated_at",
    "status",
    "rules",
    "truths"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "owner": { "type": "string" },
    "purpose": { "type": "string" },
    "authoritative": { "type": "boolean" },
    "generated_from": {
      "type": "object",
      "required": ["subagent", "run_at"],
      "properties": {
        "subagent": { "type": "string" },
        "run_at": { "type": ["string", "null"], "format": "date-time" },
        "kit_version": { "type": ["string", "null"] }
      }
    },
    "last_validated_at": { "type": ["string", "null"], "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["skeleton", "bootstrapping", "active", "stale"]
    },
    "rules": {
      "type": "object",
      "required": ["single_writer_per_truth", "readers_may_be_many", "shadow_writes_forbidden"],
      "properties": {
        "single_writer_per_truth": { "type": "boolean" },
        "readers_may_be_many": { "type": "boolean" },
        "shadow_writes_forbidden": { "type": "boolean" },
        "shadow_write_notes": { "type": "string" }
      }
    },
    "truths": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "storage", "owner_domain", "writer", "readers_allowed", "status"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "storage": { "type": "string" },
          "owner_domain": { "type": "string" },
          "writer": { "type": "string" },
          "readers_allowed": { "type": "array", "items": { "type": "string" } },
          "validation_authority": { "type": ["string", "null"] },
          "status": { "type": "string", "enum": ["proposed", "active", "deprecated"] },
          "evidence_or_judgment": { "type": "string", "enum": ["evidence", "judgment"] }
        }
      }
    },
    "agent_directives": {
      "type": "object",
      "properties": {
        "before_any_mutation": { "type": "array", "items": { "type": "string" } },
        "on_multiple_writers_discovered": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
