{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://firstlaw/schemas/project.schema.json",
  "title": "Project contract",
  "description": "Top-level identity, mode, pointers, and stack/tooling for a project the constitution kit governs.",
  "type": "object",
  "required": [
    "schema_version",
    "owner",
    "purpose",
    "authoritative",
    "generated_from",
    "last_validated_at",
    "status",
    "identity",
    "mode",
    "pointers"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "owner": { "type": "string" },
    "purpose": { "type": "string" },
    "authoritative": { "type": "boolean" },
    "generated_from": {
      "type": "object",
      "required": ["subagent", "run_at"],
      "properties": {
        "subagent": { "type": "string" },
        "run_at": { "type": ["string", "null"], "format": "date-time" },
        "kit_version": { "type": ["string", "null"] }
      }
    },
    "last_validated_at": { "type": ["string", "null"], "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["skeleton", "bootstrapping", "active", "stale"]
    },
    "identity": {
      "type": "object",
      "required": ["name", "purpose_one_line", "primary_users", "success_criteria", "anti_goals"],
      "properties": {
        "name": { "type": "string" },
        "purpose_one_line": { "type": "string" },
        "primary_users": { "type": "array", "items": { "type": "string" } },
        "success_criteria": { "type": "array", "items": { "type": "string" } },
        "anti_goals": {
          "type": "array",
          "description": "Hard stops. Each item may be a bare string (legacy) or a {goal, reason} object (preferred).",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["goal", "reason"],
                "properties": {
                  "goal": { "type": "string", "description": "The forbidden thing, stated plainly." },
                  "reason": { "type": "string", "description": "Why this is forbidden — drift prevention, scope discipline, etc." },
                  "forbidden_patterns": {
                    "type": "array",
                    "description": "Project-declared regexes flagging code violating this anti-goal. Consumed by .law/bin/check-anti-patterns. Empty = no mechanical enforcement, rely on refusing-anti-goal-creep skill.",
                    "items": { "type": "string" }
                  }
                },
                "additionalProperties": false
              }
            ]
          }
        }
      }
    },
    "mode": {
      "type": "string",
      "enum": ["greenfield", "greenfield-from-empty", "brownfield"]
    },
    "mode_notes": { "type": "string" },
    "pointers": {
      "type": "object",
      "required": ["constitution", "contracts_dir", "doctrine_dir", "charters_dir", "context_dir", "subagents_dir", "schemas_dir"],
      "properties": {
        "constitution": { "type": "string" },
        "contracts_dir": { "type": "string" },
        "doctrine_dir": { "type": "string" },
        "charters_dir": { "type": "string" },
        "context_dir": { "type": "string" },
        "subagents_dir": { "type": "string" },
        "schemas_dir": { "type": "string" }
      }
    },
    "stack": {
      "type": "object",
      "description": "Tooling/commands captured from live inspection. Pinned deps live in lockfiles (source of truth). Commands codified here.",
      "properties": {
        "language": { "type": "string" },
        "package_manager": { "type": "string" },
        "runtime": { "type": "string" },
        "build_cmd": { "type": ["string", "null"] },
        "test_cmd": { "type": ["string", "null"] },
        "lint_cmd": { "type": ["string", "null"] },
        "typecheck_cmd": { "type": ["string", "null"] },
        "dep_manifest_paths": { "type": "array", "items": { "type": "string" } },
        "lockfile_paths": { "type": "array", "items": { "type": "string" } }
      }
    },
    "adapters": {
      "type": "object",
      "properties": {
        "policy_path": { "type": "string" },
        "patched_files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "patched_at"],
            "properties": {
              "path": { "type": "string" },
              "patched_at": { "type": "string", "format": "date-time" },
              "discovery_method": {
                "type": "string",
                "enum": ["filename-heuristic", "content-heuristic", "web-research", "user-supplied"]
              }
            }
          }
        }
      }
    },
    "agent_directives": {
      "type": "object",
      "properties": {
        "on_session_start": { "type": "array", "items": { "type": "string" } },
        "on_conflict": { "type": "array", "items": { "type": "string" } }
      }
    },
    "enforcement": {
      "type": "object",
      "description": "Opt-in coupling between source paths and contract amendments. Consumed by .law/bin/check-coupling. Empty = no-op.",
      "properties": {
        "coupled_paths": {
          "type": "array",
          "description": "Glob paths where source changes require a matching .law/contracts/* amendment. Consumed by .law/bin/check-amendment-coupling (renamed in v1.4 from check-coupling). Empty = no-op. Drives amendment-coupling enforcement, NOT dependency-edge enforcement — the latter lives in dependency-rules.contract.json and is enforced by .law/bin/check-coupling.",
          "items": { "type": "string" }
        },
        "anti_patterns": {
          "type": "array",
          "description": "Project-declared anti-pattern regexes (file-size, forbidden imports, generic folder names, etc.). Consumed by .law/bin/check-anti-patterns.",
          "items": {
            "type": "object",
            "required": ["name", "pattern"],
            "properties": {
              "name": { "type": "string" },
              "pattern": { "type": "string", "description": "Regex matched line-by-line against source files." },
              "severity": {
                "type": "string",
                "enum": ["error", "warning"],
                "default": "error"
              },
              "applies_to": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Glob paths to scope this pattern. Empty = all source files."
              },
              "allowlist": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Glob paths to skip. Takes precedence over applies_to."
              },
              "rationale": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
