{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repo-constitution-kit/schemas/dependency-rules.schema.json",
  "title": "Dependency rules contract",
  "description": "Allowed and forbidden dependency edges between domains. Default stance is deny.",
  "type": "object",
  "required": [
    "schema_version",
    "owner",
    "purpose",
    "authoritative",
    "generated_from",
    "last_validated_at",
    "status",
    "rules",
    "allowed",
    "forbidden"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "owner": { "type": "string" },
    "purpose": { "type": "string" },
    "authoritative": { "type": "boolean" },
    "generated_from": {
      "type": "object",
      "required": ["subagent", "run_at"],
      "properties": {
        "subagent": { "type": "string" },
        "run_at": { "type": ["string", "null"], "format": "date-time" },
        "kit_version": { "type": ["string", "null"] }
      }
    },
    "last_validated_at": { "type": ["string", "null"], "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["skeleton", "bootstrapping", "active", "stale"]
    },
    "rules": {
      "type": "object",
      "required": ["default_stance", "cycles_forbidden", "reverse_indirection_forbidden"],
      "properties": {
        "default_stance": { "type": "string", "enum": ["deny", "allow"] },
        "default_stance_notes": { "type": "string" },
        "cycles_forbidden": { "type": "boolean" },
        "reverse_indirection_forbidden": { "type": "boolean" },
        "reverse_indirection_notes": { "type": "string" }
      }
    },
    "allowed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "reason"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "reason": { "type": "string" },
          "evidence_or_judgment": { "type": "string", "enum": ["evidence", "judgment"] }
        }
      }
    },
    "forbidden": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "reason", "severity"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "reason": { "type": "string" },
          "severity": { "type": "string", "enum": ["warn", "block"] },
          "evidence_or_judgment": { "type": "string", "enum": ["evidence", "judgment"] }
        }
      }
    },
    "agent_directives": {
      "type": "object",
      "properties": {
        "before_adding_import": { "type": "array", "items": { "type": "string" } },
        "on_discovering_existing_forbidden_edge": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
