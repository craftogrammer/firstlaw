{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://firstlaw/schemas/quality-audit.schema.json",
  "title": "Quality audit contract",
  "description": "Advisory findings from the quality-audit subagent. Advisory-only: severity informs, never halts constitution adoption.",
  "type": "object",
  "required": [
    "schema_version",
    "owner",
    "purpose",
    "authoritative",
    "generated_from",
    "last_validated_at",
    "status",
    "rules",
    "findings"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "owner": { "type": "string" },
    "purpose": { "type": "string" },
    "authoritative": { "type": "boolean" },
    "generated_from": {
      "type": "object",
      "required": ["subagent", "run_at"],
      "properties": {
        "subagent": { "type": "string" },
        "run_at": { "type": ["string", "null"], "format": "date-time" },
        "kit_version": { "type": ["string", "null"] }
      }
    },
    "last_validated_at": { "type": ["string", "null"], "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["skeleton", "bootstrapping", "active", "stale"]
    },
    "rules": {
      "type": "object",
      "required": ["advisory_only", "acknowledgement_required_for_critical"],
      "properties": {
        "advisory_only": {
          "type": "boolean",
          "description": "Quality audit findings never halt constitution adoption. Severity informs; humans decide response."
        },
        "acknowledgement_required_for_critical": {
          "type": "boolean",
          "description": "If true, critical findings require human acknowledgement recorded in the contract, but bootstrap still completes."
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "severity", "summary", "evidence", "suggested_action"],
        "properties": {
          "id": { "type": "string" },
          "category": {
            "type": "string",
            "enum": [
              "deprecated-dep",
              "cve-known",
              "outdated-major-version",
              "unmaintained-lib",
              "anti-pattern",
              "missing-tooling",
              "config-drift",
              "license-concern",
              "other"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["info", "warn", "critical"]
          },
          "summary": { "type": "string" },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["kind", "ref"],
              "properties": {
                "kind": { "type": "string", "enum": ["file", "url", "command-output"] },
                "ref": { "type": "string" },
                "retrieved_at": { "type": ["string", "null"], "format": "date-time" }
              }
            }
          },
          "suggested_action": { "type": "string" },
          "acknowledged": { "type": "boolean" },
          "acknowledged_at": { "type": ["string", "null"], "format": "date-time" },
          "acknowledged_by": { "type": ["string", "null"] }
        }
      }
    }
  }
}
